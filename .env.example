# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/telegram_ai_agent
DB_NAME=telegram_ai_agent
DB_USER=user
DB_PASS=password
DB_PORT=5432
DB_HOST=localhost

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# --- LLM ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- PROJECT ---
MODE=DEV  # DEV, PROD, TEST

# --- TELEGRAM BOT ---
BOT_WEBHOOK_BASE_URL=https://example.com
BOT_WEBHOOK_SECRET=change_me

# `DATABASE_URL` and `REDIS_URL` have priority over split DB_*/REDIS_* variables.
# `LLM_API_KEY` / `LLM_BASE_URL` are generic names; legacy `OPENROUTER_*` aliases are still accepted.
